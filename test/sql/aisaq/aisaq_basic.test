# AiSAQ basic lifecycle — Phase 5 smoke test.
#
# Exercises:
#   - CREATE INDEX ... USING AISAQ with a PQ quantizer (two-pass build)
#   - pragma_vindex_aisaq_index_info metadata
#   - the optimizer rewrites a literal-vector ORDER BY array_distance into a
#     VINDEX_INDEX_SCAN
#   - quantizer='flat' and quantizer='rabitq' are rejected (AiSAQ requires a
#     compressing, LUT-capable quantizer)
#
# Recall benches + combo_matrix cells live in Phase 7.

require vindex

statement ok
CREATE TABLE t(id INTEGER, vec FLOAT[8]);

statement ok
INSERT INTO t SELECT i::INTEGER, [i, i+1, i+2, i+3, i+4, i+5, i+6, i+7]::FLOAT[8] FROM range(1, 501) t(i);

statement ok
CREATE INDEX idx ON t USING AISAQ(vec) WITH (quantizer='pq', m=4, bits=8, aisaq_r=16, aisaq_l=64)

# The index is registered and the pragma reports it.
query I
SELECT count(*) FROM pragma_vindex_aisaq_index_info();
----
1

query T
SELECT quantizer FROM pragma_vindex_aisaq_index_info();
----
pq

# Literal query vector triggers the VINDEX_INDEX_SCAN rewrite.
query II
EXPLAIN SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5;
----
physical_plan	<REGEX>:(?s).*TOP_N.*VINDEX_INDEX_SCAN.*

# FLAT quantizer is rejected: AiSAQ needs a compressing, LUT-capable quantizer.
statement error
CREATE INDEX bad_flat ON t USING AISAQ(vec) WITH (quantizer='flat')
----
AiSAQ requires a compressing LUT-capable quantizer

# RaBitQ has no LUT distance path.
statement error
CREATE INDEX bad_rabitq ON t USING AISAQ(vec) WITH (quantizer='rabitq')
----
AiSAQ does not support quantizer='rabitq'
