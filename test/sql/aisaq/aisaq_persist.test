# name: test/sql/aisaq/aisaq_persist.test
# group: [aisaq]
#
# Checkpoint + restart round-trip. Persistence is experimental — gated on
# vindex_enable_experimental_persistence = true.

require vindex

load {TEST_DIR}/aisaq_persist.db

statement ok
SET vindex_enable_experimental_persistence = true;

statement ok
CREATE TABLE t(id INTEGER, vec FLOAT[8]);

statement ok
INSERT INTO t SELECT i::INTEGER, [i, i+1, i+2, i+3, i+4, i+5, i+6, i+7]::FLOAT[8] FROM range(1, 501) t(i);

statement ok
CREATE INDEX my_idx ON t USING AISAQ(vec) WITH (quantizer='pq', m=4, bits=8, aisaq_r=16, aisaq_l=64);

query II
EXPLAIN SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5
----
physical_plan	<REGEX>:(?s).*TOP_N.*VINDEX_INDEX_SCAN.*

query I
SELECT count(*) FROM (SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5)
----
5

statement ok
CHECKPOINT;

restart

statement ok
SET vindex_enable_experimental_persistence = true;

query II
EXPLAIN SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5
----
physical_plan	<REGEX>:(?s).*TOP_N.*VINDEX_INDEX_SCAN.*

query I
SELECT count(*) FROM (SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5)
----
5

query I
SELECT count FROM pragma_vindex_aisaq_index_info() WHERE index_name = 'my_idx'
----
500
