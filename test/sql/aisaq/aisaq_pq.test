# name: test/sql/aisaq/aisaq_pq.test
# group: [aisaq]
#
# PQ quantizer specific paths: various m/bits combinations, EXPLAIN, pragma.

require vindex

statement ok
CREATE TABLE t(id INTEGER, vec FLOAT[8]);

statement ok
INSERT INTO t SELECT i::INTEGER, [i, i+1, i+2, i+3, i+4, i+5, i+6, i+7]::FLOAT[8] FROM range(1, 501) t(i);

# m=4, bits=8
statement ok
CREATE INDEX pq_m4 ON t USING AISAQ(vec) WITH (quantizer='pq', m=4, bits=8, aisaq_r=16, aisaq_l=64);

query II
EXPLAIN SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5
----
physical_plan	<REGEX>:(?s).*TOP_N.*VINDEX_INDEX_SCAN.*

query I
SELECT count(*) FROM (SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5)
----
5

statement ok
DROP INDEX pq_m4;

# m=8, bits=4
statement ok
CREATE INDEX pq_m8_b4 ON t USING AISAQ(vec) WITH (quantizer='pq', m=8, bits=4, aisaq_r=16, aisaq_l=64);

query I
SELECT count(*) FROM (SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 3)
----
3

statement ok
DROP INDEX pq_m8_b4;

# m=8, bits=8
statement ok
CREATE INDEX pq_m8_b8 ON t USING AISAQ(vec) WITH (quantizer='pq', m=8, bits=8, aisaq_r=16, aisaq_l=64);

query I
SELECT count(*) FROM (SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 3)
----
3

statement ok
DROP INDEX pq_m8_b8;

# Pragma reports correct quantizer.
statement ok
CREATE INDEX pq_pragma ON t USING AISAQ(vec) WITH (quantizer='pq', m=4, bits=8, aisaq_r=16, aisaq_l=64);

query T
SELECT quantizer FROM pragma_vindex_aisaq_index_info() WHERE index_name = 'pq_pragma'
----
pq

query I
SELECT graph_degree FROM pragma_vindex_aisaq_index_info() WHERE index_name = 'pq_pragma'
----
16

statement ok
DROP INDEX pq_pragma;
