# name: test/sql/aisaq/aisaq_pragma.test
# group: [aisaq]
#
# pragma_vindex_aisaq_index_info metadata + session overrides.

require vindex

statement ok
CREATE TABLE t(id INTEGER, vec FLOAT[8]);

statement ok
INSERT INTO t SELECT i::INTEGER, [i, i+1, i+2, i+3, i+4, i+5, i+6, i+7]::FLOAT[8] FROM range(1, 501) t(i);

statement ok
CREATE INDEX my_idx ON t USING AISAQ(vec) WITH (quantizer='pq', m=4, bits=8, aisaq_r=16, aisaq_l=64);

# One row for the index.
query I
SELECT count(*) FROM pragma_vindex_aisaq_index_info() WHERE index_name = 'my_idx'
----
1

# Verify key columns.
query T
SELECT metric FROM pragma_vindex_aisaq_index_info() WHERE index_name = 'my_idx'
----
l2sq

query T
SELECT quantizer FROM pragma_vindex_aisaq_index_info() WHERE index_name = 'my_idx'
----
pq

query I
SELECT dimensions FROM pragma_vindex_aisaq_index_info() WHERE index_name = 'my_idx'
----
8

query III
SELECT graph_degree, beam_width, entry_points FROM pragma_vindex_aisaq_index_info() WHERE index_name = 'my_idx'
----
16	64	16

query II
SELECT inline_pq, count FROM pragma_vindex_aisaq_index_info() WHERE index_name = 'my_idx'
----
0	500

# Session override: vindex_aisaq_l_search affects search but not the pragma.
statement ok
SET vindex_aisaq_l_search = 200;

query II
EXPLAIN SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5
----
physical_plan	<REGEX>:(?s).*TOP_N.*VINDEX_INDEX_SCAN.*

query I
SELECT count(*) FROM (SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5)
----
5

statement ok
RESET vindex_aisaq_l_search;

# Session override: vindex_rerank_multiple.
statement ok
SET vindex_rerank_multiple = 20;

query II
EXPLAIN SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5
----
physical_plan	<REGEX>:(?s).*TOP_N.*VINDEX_INDEX_SCAN.*

statement ok
RESET vindex_rerank_multiple;
