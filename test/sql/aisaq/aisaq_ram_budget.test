# name: test/sql/aisaq/aisaq_ram_budget.test
# group: [aisaq]
#
# Verify AiSAQ works under memory pressure. Two modes:
#   Part A: explicit build_strategy='paged' — forces Tier 1 (per-prune gather,
#           BufferManager-mediated access). No flat buffers allocated.
#   Part B: SET memory_limit — forces auto-selection to pick 'paged' because
#           flat buffers exceed the budget.

require vindex

statement ok
CREATE TABLE t(id INTEGER, vec FLOAT[8]);

statement ok
INSERT INTO t SELECT i::INTEGER, [i, i+1, i+2, i+3, i+4, i+5, i+6, i+7]::FLOAT[8] FROM range(1, 5001) t(i);

# --- Part A: explicit paged build strategy -------------------------------

statement ok
CREATE INDEX idx_paged ON t USING AISAQ(vec) WITH (quantizer='pq', m=4, bits=8, aisaq_r=16, aisaq_l=64, build_strategy='paged');

query II
EXPLAIN SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5
----
physical_plan	<REGEX>:(?s).*TOP_N.*VINDEX_INDEX_SCAN.*

query I
SELECT count(*) FROM (SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5)
----
5

statement ok
DROP INDEX idx_paged;

# --- Part B: tight memory_limit forces auto to pick paged ----------------

statement ok
SET memory_limit='64MB';

statement ok
CREATE INDEX idx_auto ON t USING AISAQ(vec) WITH (quantizer='pq', m=4, bits=8, aisaq_r=16, aisaq_l=64, build_strategy='auto');

query II
EXPLAIN SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5
----
physical_plan	<REGEX>:(?s).*TOP_N.*VINDEX_INDEX_SCAN.*

query I
SELECT count(*) FROM (SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5)
----
5

statement ok
DROP INDEX idx_auto;

# --- Part C: default memory_limit — auto should pick pq_buffer ------------

statement ok
RESET memory_limit;

statement ok
CREATE INDEX idx_default ON t USING AISAQ(vec) WITH (quantizer='pq', m=4, bits=8, aisaq_r=16, aisaq_l=64);

query I
SELECT count(*) FROM (SELECT id FROM t ORDER BY array_distance(vec, [10,11,12,13,14,15,16,17]::FLOAT[8]) LIMIT 5)
----
5
