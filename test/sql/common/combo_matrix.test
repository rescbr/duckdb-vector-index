# ============================================================================
# AiSAQ — rejects flat (needs compressing LUT quantizer) and rabitq (no LUT).
# ============================================================================

# -- aisaq × flat (all rejected) ----------------------------------------------

statement error
CREATE INDEX aisaq_flat_l2sq ON t USING AISAQ (vec) WITH (metric='l2sq', quantizer='flat');
----
AiSAQ requires a compressing LUT-capable quantizer

statement error
CREATE INDEX aisaq_flat_cosine ON t USING AISAQ (vec) WITH (metric='cosine', quantizer='flat');
----
AiSAQ requires a compressing LUT-capable quantizer

statement error
CREATE INDEX aisaq_flat_ip ON t USING AISAQ (vec) WITH (metric='ip', quantizer='flat');
----
AiSAQ requires a compressing LUT-capable quantizer

# -- aisaq × rabitq (all rejected) --------------------------------------------

statement error
CREATE INDEX aisaq_rabitq_l2sq ON t USING AISAQ (vec) WITH (metric='l2sq', quantizer='rabitq', bits=3);
----
AiSAQ does not support quantizer='rabitq'

statement error
