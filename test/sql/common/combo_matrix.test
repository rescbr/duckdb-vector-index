statement ok
DROP INDEX ivf_rabitq_ip;

# -- ivf × pq -----------------------------------------------------------------

statement ok
CREATE INDEX ivf_pq_l2sq ON t USING IVF (vec) WITH (metric='l2sq', quantizer='pq', m=8, bits=4, nlist=4);

statement ok
DROP INDEX ivf_pq_l2sq;

statement error
CREATE INDEX ivf_pq_cosine ON t USING IVF (vec) WITH (metric='cosine', quantizer='pq', m=8, bits=4, nlist=4);
----
PQ quantizer does not support cosine

statement ok
CREATE INDEX ivf_pq_ip ON t USING IVF (vec) WITH (metric='ip', quantizer='pq', m=8, bits=4, nlist=4);

statement ok
DROP INDEX ivf_pq_ip;

# -- ivf × scann --------------------------------------------------------------

statement ok
CREATE INDEX ivf_scann_l2sq ON t USING IVF (vec) WITH (metric='l2sq', quantizer='scann', m=8, bits=4, nlist=4);

statement ok
DROP INDEX ivf_scann_l2sq;

statement error
